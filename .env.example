# Primary connection string — used by the application at runtime.
# On Railway with PgBouncer, this points to the pooled connection.
DATABASE_URL="postgresql://user:password@localhost:5432/fidant_dev"

# Direct connection to PostgreSQL — bypasses PgBouncer.
# DIRECT_URL is required for Prisma migrations (`prisma migrate deploy`)
# because migrations use advisory locks and temp tables that don't work
# through a connection pooler like PgBouncer.
DIRECT_URL="postgresql://user:password@localhost:5432/fidant_dev"
