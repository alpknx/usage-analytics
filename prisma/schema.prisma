generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────

enum PlanTier {
  starter
  pro
  executive
}

enum EventType {
  committed
  reserved
}

// ─── Models ────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  plan      PlanTier @default(starter)
  createdAt DateTime @default(now()) @map("created_at")

  events DailyUsageEvent[]
  caches DailyUsageCache[]

  @@map("users")
}

model DailyUsageEvent {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  type      EventType
  dateKey   String    @map("date_key") // "YYYY-MM-DD" in UTC
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
  @@map("daily_usage_events")
}

model DailyUsageCache {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  dateKey        String   @map("date_key") // "YYYY-MM-DD" in UTC
  committedCount Int      @default(0) @map("committed_count")
  reservedCount  Int      @default(0) @map("reserved_count")
  isTodayCache   Boolean  @default(false) @map("is_today_cache")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, dateKey])
  @@map("daily_usage_cache")
}
